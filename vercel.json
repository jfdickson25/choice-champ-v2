{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/cron/:path*", "destination": "/api/cron/:path*" },
    { "source": "/api/:path*",      "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/cleanup-parties",
      "schedule": "0 0 * * *"
    }
  ]
}
